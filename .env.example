# Neon PostgreSQL connection string
# Get it from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clave maestra para crear nuevos equipos (solo el admin la conoce)
# Configúrala en Vercel → Settings → Environment Variables
ADMIN_KEY=tu-clave-secreta-aqui
